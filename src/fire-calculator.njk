{% import "macros.njk" as m %}

<div class="calc">
  <div class="inputs">
    {{ m.field('e', 'Current annual expenses', '₹', 100000, 10000000, 50000, 600000, '₹1L', '₹1 Cr') }}
    {{ m.field('n', 'Years until retirement', 'years', 1, 40, 1, 15, '1 yr', '40 yrs') }}
    {{ m.field('inf', 'Expected inflation', '%', 2, 12, 0.5, 6, '2%', '12%') }}
    {{ m.field('wr', 'Safe withdrawal rate', '%', 2.5, 5, 0.25, 4, '2.5% (33x+)', '5% (20x)') }}
    {{ m.field('r', 'Return on investments (p.a.)', '%', 6, 20, 0.5, 12, '6%', '20%') }}
