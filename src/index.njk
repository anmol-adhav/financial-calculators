  {% set cats = [
    { name: "Loans", blurb: "Know the true cost of borrowing before you sign." },
    { name: "Investments", blurb: "Project SIPs, lumpsums and long-term compounding." },
    { name: "Deposits", blurb: "Bank-accurate maths for FDs, RDs and PPF." },
    { name: "Tax", blurb: "FY 2025-26 income tax and current GST rates." },
